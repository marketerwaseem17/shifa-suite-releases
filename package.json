{
  "name": "shifa-suite",
  "private": true,
  "version": "1.0.0",
  "description": "Shifa Suite — complete offline clinic management for Pakistani clinics",
  "author": "Waseem",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "dist:dir": "npm run build && electron-builder --config electron-builder.yml --dir",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "exceljs": "^4.4.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "electron": "31.7.7",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
